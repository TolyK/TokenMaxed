# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo
# NOTE: packages/plugin/server/index.mjs is intentionally COMMITTED (it is the
# self-contained install artifact the plugin launches); rebuild it with
# `npm run build:plugin` whenever the MCP server or core changes.

# Local runtime data (the ledger lives in the user's home dir, never in the repo)
*.jsonl
.tokenmaxed/

# User's local lane config (only the .example is tracked)
config/lanes.yaml
config/policy.yaml

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Env
.env
.env.*
!.env.example

# Agent worktrees (created by Claude Code subagent isolation)
.claude/worktrees/
# Runtime locks/state (machine- & session-specific; never commit)
.claude/scheduled_tasks.lock
.claude/*.lock
# Personal per-machine settings overrides (e.g. TOKENMAXED_REVIEW_ON_STOP for a
# machine where the codex CLI cold-start exceeds the Stop-review timeout)
.claude/settings.local.json
