{
  "name": "tokenmaxed",
  "displayName": "TokenMaxed",
  "version": "0.0.0",
  "description": "Route each coding task to the cheapest capable, policy-allowed lane — local-first, content-free.",
  "author": { "name": "TolyK", "url": "https://github.com/TolyK" },
  "homepage": "https://github.com/TolyK/TokenMaxed",
  "repository": "https://github.com/TolyK/TokenMaxed",
  "license": "MIT",
  "keywords": ["router", "cost", "claude-code", "mcp", "tokens"],
  "mcpServers": {
    "tokenmaxed": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/server/index.mjs"],
      "env": {
        "TOKENMAXED_PRICES": "${CLAUDE_PLUGIN_ROOT}/prices.seed.json",
        "TOKENMAXED_STATE": "${CLAUDE_PLUGIN_DATA}/state.json",
        "TOKENMAXED_PROJECT": "${CLAUDE_PROJECT_DIR}"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sessionstart.mjs\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_tokenmaxed_tokenmaxed__router_delegate",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/stop.mjs\""
          }
        ]
      }
    ]
  }
}
